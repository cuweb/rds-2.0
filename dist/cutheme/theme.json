{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "custom": false,
      "customDuotone": false,
      "customGradient": false,
      "palette": [
        {
          "slug": "primary",
          "color": "#e91c24",
          "name": "Primary"
        },
        {
          "slug": "primary-dark",
          "color": "#a21218",
          "name": "Primary Dark"
        },
        {
          "slug": "secondary",
          "color": "#426587",
          "name": "Secondary"
        },
        {
          "slug": "black",
          "color": "#191919",
          "name": "Black"
        },
        {
          "slug": "grey-dark",
          "color": "#434343",
          "name": "Grey Dark"
        },
        {
          "slug": "grey",
          "color": "#767676",
          "name": "Grey"
        },
        {
          "slug": "grey-light",
          "color": "#d6d6d6",
          "name": "Grey Light"
        },
        {
          "slug": "grey-lighter",
          "color": "#e6e6e6",
          "name": "Grey Lighter"
        },
        {
          "slug": "grey-pale",
          "color": "#f5f5f5",
          "name": "Grey Pale"
        },
        {
          "slug": "grey-faint",
          "color": "#fafafa",
          "name": "Grey Faint"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        }
      ],
      "gradients": [
        {
          "slug": "custom-red-to-dark-red",
          "gradient": "linear-gradient(135deg,rgb(233,28,36) 0%,rgb(25,25,25) 100%)",
          "name": "Red To Dark Red"
        },
        {
          "slug": "custom-dark-grey-to-black",
          "gradient": "linear-gradient(135deg,rgb(118,118,118) 0%,rgb(25,25,25) 100%)",
          "name": "Dark Grey To Black"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "slug": "20",
          "size": "0.25rem",
          "name": "2x Small"
        },
        {
          "slug": "30",
          "size": "0.5rem",
          "name": "X Small"
        },
        {
          "slug": "40",
          "size": "min(0.75rem, 1vw)",
          "name": "Small"
        },
        {
          "slug": "50",
          "size": "min(1.5rem, 2vw)",
          "name": "Medium"
        },
        {
          "slug": "60",
          "size": "min(2.25rem, 3vw)",
          "name": "Large"
        },
        {
          "slug": "70",
          "size": "min(3rem, 4vw)",
          "name": "X Large"
        },
        {
          "slug": "80",
          "size": "min(4.5rem, 6vw)",
          "name": "2x Large"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "inter",
          "fontFamily": "Inter, sans-serif",
          "name": "Inter",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "300",
              "src": [
                "file:./assets/fonts/inter/inter-300-normal.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/inter/inter-400-normal.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": [
                "file:./assets/fonts/inter/inter-700-normal.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "italic",
              "fontWeight": "300",
              "src": [
                "file:./assets/fonts/inter/inter-300-italic.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "italic",
              "fontWeight": "400",
              "src": [
                "file:./assets/fonts/inter/inter-400-italic.woff2"
              ]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "italic",
              "fontWeight": "700",
              "src": [
                "file:./assets/fonts/inter/inter-700-italic.woff2"
              ]
            }
          ]
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.9rem",
          "name": "Small",
          "fluid": {
            "min": "0.75rem",
            "max": "0.9rem"
          }
        },
        {
          "slug": "medium",
          "size": "1rem",
          "name": "Medium",
          "fluid": {
            "min": "0.875rem",
            "max": "1rem"
          }
        },
        {
          "slug": "large",
          "size": "1.125rem",
          "name": "Large",
          "fluid": {
            "min": "1rem",
            "max": "1.125rem"
          }
        },
        {
          "slug": "x-large",
          "size": "1.25rem",
          "name": "X Large",
          "fluid": {
            "min": "1.125rem",
            "max": "1.25rem"
          }
        },
        {
          "slug": "2x-large",
          "size": "1.5rem",
          "name": "2x Large",
          "fluid": {
            "min": "1.25rem",
            "max": "1.5rem"
          }
        },
        {
          "slug": "heading-small",
          "size": "1.5rem",
          "name": "Heading Small",
          "fluid": {
            "min": "1.25rem",
            "max": "1.5rem"
          }
        },
        {
          "slug": "heading-medium",
          "size": "2rem",
          "name": "Heading Medium",
          "fluid": {
            "min": "1.75rem",
            "max": "2rem"
          }
        },
        {
          "slug": "heading-large",
          "size": "2.5rem",
          "name": "Heading Large",
          "fluid": {
            "min": "2rem",
            "max": "2.5rem"
          }
        },
        {
          "slug": "heading-x-large",
          "size": "3rem",
          "name": "Heading X Large",
          "fluid": {
            "min": "2.5rem",
            "max": "3rem"
          }
        },
        {
          "slug": "heading-primary",
          "size": "3.5rem",
          "name": "Heading Primary",
          "fluid": {
            "min": "3rem",
            "max": "3.5rem"
          }
        }
      ],
      "fluid": true
    },
    "shadow": {
      "presets": [
        {
          "slug": "natural",
          "shadow": "6px 6px 9px rgba(0, 0, 0, 0.2)",
          "name": "Natural"
        },
        {
          "slug": "sharp",
          "shadow": "6px 6px 0px rgba(0, 0, 0, 0.2)",
          "name": "Sharp"
        },
        {
          "slug": "outlined",
          "shadow": "6px 6px 0px -3px rgb(255, 255, 255), 6px 6px rgb(214, 214, 214)",
          "name": "Outlined"
        }
      ]
    },
    "layout": {
      "contentSize": "1024px",
      "wideSize": "1280px"
    },
    "custom": {
      "fontWeight": {
        "light": "300",
        "normal": "400",
        "medium": "500",
        "bold": "700"
      },
      "lineHeight": {
        "tight": "1.2",
        "normal": "1.6",
        "loose": "1.8"
      },
      "radius": {
        "sm": "2px",
        "md": "4px",
        "lg": "8px"
      }
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--large)",
      "fontWeight": "400",
      "lineHeight": "1.6"
    },
    "color": {
      "text": "var(--wp--preset--color--black)",
      "background": "var(--wp--preset--color--grey-faint)"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--50)",
      "padding": {
        "top": "0",
        "right": "var(--wp--preset--spacing--60)",
        "bottom": "0",
        "left": "var(--wp--preset--spacing--60)"
      }
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)"
        },
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--heading-primary)",
          "fontStyle": "normal",
          "fontWeight": "500"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--heading-x-large)",
          "fontStyle": "normal",
          "fontWeight": "500"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--heading-large)",
          "fontStyle": "normal",
          "fontWeight": "500"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--heading-medium)",
          "fontStyle": "normal",
          "fontWeight": "500"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--heading-small)",
          "fontStyle": "normal",
          "fontWeight": "500"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--heading-small)",
          "fontStyle": "italic",
          "fontWeight": "500"
        }
      },
      "caption": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontStyle": "italic",
          "fontWeight": "300"
        },
        "color": {
          "text": "#dba617"
        }
      },
      "button": {
        "color": {
          "text": "var(--wp--preset--color--white)",
          "background": "var(--wp--preset--color--primary)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "#e91c24"
          }
        }
      }
    }
  }
}
