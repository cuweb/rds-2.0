{
    "prefix": "rds",

    "output": {
        "tokensPath": "src/styles/automated/tokens.css",
        "wpDir": "dist/cutheme",
        "wpThemeable": false
    },

    "tokens": {
        "layout": {
            "contentSize": "1024px",
            "wideSize": "1280px"
        },

        "color": {
            "primary": "#e91c24",
            "primary-dark": "#a21218",
            "primary-faint": { "value": "#fff1f2", "cssOnly": true },
            "secondary": "#426587",
            "secondary-dark": { "value": "#2c3c4e", "cssOnly": true },
            "success": { "value": "#00a32a", "cssOnly": true },
            "warning": { "value": "#dba617", "cssOnly": true },
            "error": { "value": "#e91c24", "cssOnly": true },
            "info": { "value": "#72aee6", "cssOnly": true },
            "black": "#191919",
            "grey-dark": "#434343",
            "grey": "#767676",
            "grey-light": "#d6d6d6",
            "grey-lighter": "#e6e6e6",
            "grey-pale": "#f5f5f5",
            "grey-faint": "#fafafa",
            "white": "#ffffff"
        },

        "gradient": {
            "fade-out": {
                "value": "linear-gradient(135deg,rgb(134,255,223) 0%,rgb(143,51,228) 100%)",
                "slug": "custom-fade-out"
            },
            "fade-in": {
                "value": "linear-gradient(0deg,rgb(227,7,97) 0%,rgb(0,195,255) 100%)",
                "slug": "custom-fade-in"
            }
        },

        "fontFamily": {
            "inter": {
                "value": "Inter, sans-serif",
                "fontFace": [
                    { "weight": "400", "style": "normal", "src": "inter-400-normal.woff2" }
                ]
            },
            "system": "-apple-system, BlinkMacSystemFont, sans-serif"
        },

        "fontSize": {
            "x-small":    { "min": "0.65rem", "max": "0.75rem", "cssOnly": true },
            "small":    { "min": "0.875rem", "max": "1rem" },
            "medium":   { "min": "1rem",     "max": "1.125rem" },
            "large":    { "min": "1.125rem", "max": "1.25rem" },
            "x-large":  { "min": "1.25rem",  "max": "1.5rem" },
            "2x-large": { "value": "1.875rem", "fluid": { "min": "1.5rem", "max": "1.875rem" }, "cssOnly": true },
            "3x-large": { "value": "2.25rem",  "fluid": { "min": "1.875rem", "max": "2.25rem" }, "cssOnly": true },
            "4x-large": { "value": "3rem",     "fluid": { "min": "2.25rem", "max": "3rem" }, "cssOnly": true },
            "5x-large": { "value": "3.75rem",  "fluid": { "min": "2.75rem", "max": "3.75rem" }, "cssOnly": true },
            "6x-large": { "value": "4.5rem",   "fluid": { "min": "3.25rem", "max": "4.5rem" }, "cssOnly": true }
        },

        "spacing": {
            "2x-small": { "value": "0.25rem", "slug": "20" },
            "x-small":  { "value": "0.5rem",  "slug": "30" },
            "small":    { "value": "min(0.75rem, 1vw)",  "slug": "40" },
            "medium":   { "value": "min(1.5rem, 2vw)",   "slug": "50" },
            "large":    { "value": "min(2.25rem, 3vw)",   "slug": "60" },
            "x-large":  { "value": "min(3rem, 4vw)",      "slug": "70" },
            "2x-large": { "value": "min(4.5rem, 6vw)",    "slug": "80" }
        },

        "shadow": {
            "natural":  "6px 6px 9px rgba(0, 0, 0, 0.2)",
            "sharp":    "6px 6px 0px rgba(0, 0, 0, 0.2)",
            "outlined": "6px 6px 0px -3px rgb(255, 255, 255), 6px 6px rgb(214, 214, 214)"
        },

        "fontWeight": {
            "light":  "300",
            "normal": "400",
            "medium": "500",
            "bold":   "700"
        },

        "lineHeight": {
            "tight":  "1.2",
            "normal": "1.6",
            "loose":  "1.8"
        },

        "radius": {
            "sm": "2px",
            "md": "4px",
            "lg": "8px"
        }
    },

    "baseStyles": {
        "body": {
            "fontFamily": "inter",
            "fontSize": "medium",
            "fontWeight": "normal",
            "lineHeight": "normal",
            "color": "black",
            "background": "grey-faint"
        },
        "heading": {
            "fontFamily": "inter",
            "color": "primary"
        },
        "h1": { "fontSize": "6x-large", "fontWeight": "medium" },
        "h2": { "fontSize": "5x-large", "fontWeight": "medium" },
        "h3": { "fontSize": "4x-large", "fontWeight": "medium" },
        "h4": { "fontSize": "3x-large", "fontWeight": "medium" },
        "h5": { "fontSize": "2x-large", "fontWeight": "medium" },
        "h6": { "fontSize": "x-large", "fontWeight": "medium", "fontStyle": "italic" },
        "caption": { "fontSize": "small", "fontStyle": "italic", "fontWeight": "light", "color": "warning" },
        "button": { "color": "white", "background": "primary" },
        "link": { "color": "primary", "hoverColor": "error" },
        "spacing": {
            "blockGap": "medium",
            "padding": {
                "top": "0",
                "right": "large",
                "bottom": "0",
                "left": "large"
            }
        }
    }
}
